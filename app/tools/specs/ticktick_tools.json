{
  "version": 1,
  "tools": [
    {
      "name": "create_task",
      "description": "Creates a new TickTick task. Use for adding a task, reminder, or to-do item.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Task title."
          },
          "project_id": {
            "type": "string",
            "description": "Optional TickTick project identifier. Omit to use the configured default/inbox project."
          },
          "content": {
            "type": "string",
            "description": "Optional task notes or description."
          },
          "due_date": {
            "type": "string",
            "description": "Due date or datetime in ISO-like format understood by TickTick, for example 2026-04-24 or 2026-04-24T09:00:00+0300."
          },
          "start_date": {
            "type": "string",
            "description": "Optional start date or datetime in ISO-like format."
          },
          "is_all_day": {
            "type": "boolean",
            "description": "Whether the task is an all-day task."
          },
          "time_zone": {
            "type": "string",
            "description": "IANA timezone name to use for task date normalization, for example Europe/Moscow."
          },
          "priority": {
            "type": "integer",
            "description": "Optional TickTick priority value.",
            "enum": [0, 1, 3, 5]
          }
        },
        "required": ["title"],
        "additionalProperties": false
      }
    },
    {
      "name": "list_tasks",
      "description": "Lists or searches TickTick tasks by status, project, or text query.",
      "parameters": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Optional task status filter.",
            "enum": ["normal", "open", "completed", "done"]
          },
          "project_id": {
            "type": "string",
            "description": "Optional project identifier."
          },
          "search": {
            "type": "string",
            "description": "Optional case-insensitive text query matched against task title and content."
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "get_task_details",
      "description": "Gets full details for one TickTick task by task_id.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "TickTick task identifier."
          }
        },
        "required": ["task_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "create_subtasks",
      "description": "Creates subtasks under an existing TickTick task.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Parent task identifier."
          },
          "titles": {
            "type": "array",
            "description": "Subtask titles to create.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["task_id", "titles"],
        "additionalProperties": false
      }
    },
    {
      "name": "update_task",
      "description": "Updates editable fields of a TickTick task by task_id.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "TickTick task identifier."
          },
          "title": {
            "type": "string",
            "description": "New task title."
          },
          "content": {
            "type": "string",
            "description": "New task notes or description."
          },
          "due_date": {
            "type": "string",
            "description": "New due date or datetime."
          },
          "start_date": {
            "type": "string",
            "description": "New start date or datetime."
          },
          "is_all_day": {
            "type": "boolean",
            "description": "Whether the task should be treated as all-day."
          },
          "time_zone": {
            "type": "string",
            "description": "IANA timezone name used for date normalization."
          },
          "priority": {
            "type": "integer",
            "description": "New TickTick priority value.",
            "enum": [0, 1, 3, 5]
          },
          "status": {
            "type": "string",
            "description": "Optional task status value.",
            "enum": ["normal", "open", "completed", "done"]
          },
          "project_id": {
            "type": "string",
            "description": "Optional new project identifier."
          }
        },
        "required": ["task_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "update_task_by_search",
      "description": "Searches open tasks by text and updates the matching task only when the result is unambiguous.",
      "parameters": {
        "type": "object",
        "properties": {
          "search": {
            "type": "string",
            "description": "Text query used to find the task by title or content."
          },
          "title": {
            "type": "string",
            "description": "New task title."
          },
          "content": {
            "type": "string",
            "description": "New task notes or description."
          },
          "due_date": {
            "type": "string",
            "description": "New due date or datetime."
          },
          "start_date": {
            "type": "string",
            "description": "New start date or datetime."
          },
          "is_all_day": {
            "type": "boolean",
            "description": "Whether the task should be treated as all-day."
          },
          "time_zone": {
            "type": "string",
            "description": "IANA timezone name used for date normalization."
          },
          "priority": {
            "type": "integer",
            "description": "New TickTick priority value.",
            "enum": [0, 1, 3, 5]
          },
          "status": {
            "type": "string",
            "description": "Optional task status value.",
            "enum": ["normal", "open", "completed", "done"]
          },
          "project_id": {
            "type": "string",
            "description": "Optional project filter for the search or target project if moving the task."
          },
          "prefer_due_date": {
            "type": "string",
            "description": "Optional preferred due date in YYYY-MM-DD when several tasks match."
          },
          "prefer_today": {
            "type": "boolean",
            "description": "Prefer tasks due today when several tasks match."
          },
          "exact_title": {
            "type": "boolean",
            "description": "Require exact title match before updating.",
            "default": false
          }
        },
        "required": ["search"],
        "additionalProperties": false
      }
    },
    {
      "name": "list_projects",
      "description": "Lists available TickTick projects and can optionally filter them by query.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Optional case-insensitive filter by project name or id."
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "list_upcoming_tasks",
      "description": "Lists open tasks due within a date window, sorted by local due date.",
      "parameters": {
        "type": "object",
        "properties": {
          "days": {
            "type": "integer",
            "description": "How many days ahead to include.",
            "default": 30
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of tasks to return.",
            "default": 10
          },
          "include_overdue": {
            "type": "boolean",
            "description": "Whether to include overdue tasks.",
            "default": false
          },
          "include_without_due_date": {
            "type": "boolean",
            "description": "Whether to append tasks without due dates after dated tasks.",
            "default": false
          },
          "project_id": {
            "type": "string",
            "description": "Optional project identifier."
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "move_task",
      "description": "Moves a task to another TickTick project.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "TickTick task identifier."
          },
          "project_id": {
            "type": "string",
            "description": "Destination project identifier."
          }
        },
        "required": ["task_id", "project_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "mark_complete",
      "description": "Marks a TickTick task as completed.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "TickTick task identifier."
          }
        },
        "required": ["task_id"],
        "additionalProperties": false
      }
    }
  ]
}
